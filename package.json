{
  "name": "vortex-pos",
  "version": "1.1.0",
  "description": "Vortex POS System - Modern Restaurant Management Solution",
  "author": "Adham Nemr",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "start:electron": "electron .",
    "dist:win": "electron-builder --win --x64",
    "test": "jest --detectOpenHandles --forceExit"
  },
  "build": {
    "appId": "com.bazzez.pos",
    "productName": "Vortex POS",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sqlite3/**"
    ],
    "files": [
      "main.js",
      "server.js",
      ".env",
      "public/**/*",
      "controllers/**/*",
      "models/**/*",
      "routes/**/*",
      "middleware/**/*",
      "services/**/*",
      "config/**/*",
      "utils/**/*",
      "node_modules/**/*",
      "!dist/**/*",
      "!**/*.md",
      "!node_modules/.cache/**/*",
      "!backups/**/*",
      "!tests/**/*",
      "!**/*.test.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/img/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vortex POS"
    }
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "escpos": "^3.0.0-alpha.6",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "iconv-lite": "^0.7.2",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "node-thermal-printer": "^4.4.4",
    "pdfkit": "^0.16.0",
    "sequelize": "^6.35.2",
    "sqlite3": "^6.0.1",
    "wait-on": "^9.0.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^39.8.10",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  }
}
