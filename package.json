{
  "name": "vortex-pos",
  "version": "1.1.0",
  "description": "Vortex POS System - Modern Restaurant Management Solution",
  "author": "Adham Nemr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adhamNemr/Bazzez_Project.git"
  },
  "keywords": [
    "pos",
    "point-of-sale",
    "restaurant",
    "electron",
    "nodejs",
    "express",
    "mysql",
    "javascript"
  ],
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "start:electron": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.bazzez.pos",
    "productName": "Vortex POS",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.business"
    },
    "win": {
      "target": "nsis",
      "icon": "public/img/logo.png"
    }
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "escpos": "^3.0.0-alpha.6",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "iconv-lite": "^0.7.2",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mysql2": "^3.6.5",
    "node-thermal-printer": "^4.4.4",
    "pdfkit": "^0.16.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.2",
    "wait-on": "^9.0.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^39.2.5",
    "electron-builder": "^26.0.12"
  }
}
